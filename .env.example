# Repository-level local development defaults.
# Copy to .env only if you want to override Docker Compose defaults.

POSTGRES_USER=localco
POSTGRES_PASSWORD=localco_dev
POSTGRES_DB=localco_db
POSTGRES_PORT=5432

API_PORT=4000
WEB_PORT=3000
SHOP_PORT=3001

DATABASE_URL=postgresql://localco:localco_dev@postgres:5432/localco_db
HOST_DATABASE_URL=postgresql://localco:localco_dev@localhost:5432/localco_db

BETTER_AUTH_SECRET=replace-with-a-long-random-string-for-local-development
BETTER_AUTH_URL=http://localhost:4000

FRONTEND_URL=http://localhost:3000
SHOP_PUBLIC_URL=http://localhost:3001
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CHECKOUT_RATE_LIMIT_WINDOW_MS=60000
CHECKOUT_RATE_LIMIT_MAX=10
ABANDONED_ORDER_DELAY_MINUTES=60

NEXT_PUBLIC_API_URL=http://localhost:4000/api
API_INTERNAL_URL=http://api:4000/api
NEXT_PUBLIC_AUTH_URL=http://localhost:4000

# Required for /api/health/ready to report Stripe as configured.
# Use a real Stripe test secret key, for example sk_test_...
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_PROCESSING_TIMEOUT_MS=300000
STRIPE_RECONCILIATION_WORKER_ENABLED=false
STRIPE_RECONCILIATION_WORKER_INTERVAL_MS=60000
STRIPE_RECONCILIATION_BATCH_SIZE=10
STRIPE_RECONCILIATION_MAX_ATTEMPTS=5
STRIPE_RECONCILIATION_BACKOFF_BASE_MS=60000
STRIPE_RECONCILIATION_BACKOFF_MAX_MS=3600000
STRIPE_RECONCILIATION_LEASE_MS=300000

# Required for /api/health/ready to report Resend as configured.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

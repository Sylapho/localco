{
  "name": "localco",
  "private": true,
  "version": "1.0.0",
  "description": "LocalCo monorepo",
  "scripts": {
    "dev": "pnpm -r --parallel --if-present dev",
    "dev:api": "pnpm --filter @localco/api start:dev",
    "dev:web": "pnpm --filter @localco/web dev",
    "dev:shop": "pnpm --filter @localco/shop dev",
    "check": "pnpm lint && pnpm test:api --runInBand && pnpm build",
    "build": "pnpm build:api && pnpm build:web && pnpm build:shop",
    "build:api": "pnpm --filter @localco/api build",
    "build:web": "pnpm --filter @localco/web build",
    "build:shop": "pnpm --filter @localco/shop build",
    "lint": "pnpm -r --if-present lint",
    "lint:api": "pnpm --filter @localco/api lint",
    "lint:web": "pnpm --filter @localco/web lint",
    "lint:shop": "pnpm --filter @localco/shop lint",
    "test": "pnpm test:api",
    "test:api": "pnpm --filter @localco/api test",
    "test:api:e2e": "pnpm --filter @localco/api test:e2e",
    "test:shop:e2e": "pnpm --filter @localco/shop test:e2e",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d postgres",
    "docker:dev": "docker compose up --build",
    "docker:dev:detached": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:down:volumes": "docker compose down -v",
    "docker:logs": "docker compose logs -f",
    "docker:ps": "docker compose ps",
    "docker:db": "docker compose up -d postgres",
    "docker:db:logs": "docker compose logs -f postgres",
    "db:generate": "pnpm --filter @localco/api exec prisma generate",
    "db:migrate": "pnpm --filter @localco/api exec prisma migrate dev",
    "db:deploy": "pnpm --filter @localco/api exec prisma migrate deploy",
    "db:seed": "pnpm --filter @localco/api seed",
    "prisma:generate": "pnpm db:generate",
    "prisma:migrate": "pnpm db:migrate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0"
}

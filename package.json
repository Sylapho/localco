{
  "name": "localco",
  "private": true,
  "version": "1.0.0",
  "description": "LocalCo monorepo",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:api": "pnpm --filter @localco/api start:dev",
    "dev:web": "pnpm --filter web dev",
    "dev:shop": "pnpm --filter shop dev",
    "build": "pnpm build:api && pnpm build:web",
    "build:api": "pnpm --filter @localco/api build",
    "build:web": "pnpm --filter web build",
    "build:shop": "pnpm --filter shop build",
    "lint": "pnpm -r lint",
    "lint:api": "pnpm --filter @localco/api lint",
    "lint:web": "pnpm --filter web lint",
    "test": "pnpm test:api",
    "test:api": "pnpm --filter @localco/api test",
    "test:api:e2e": "pnpm --filter @localco/api test:e2e",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d",
    "db:generate": "pnpm --filter @localco/api exec prisma generate",
    "db:migrate": "pnpm --filter @localco/api exec prisma migrate dev",
    "db:deploy": "pnpm --filter @localco/api exec prisma migrate deploy",
    "db:seed": "pnpm --filter @localco/api seed",
    "prisma:generate": "pnpm db:generate",
    "prisma:migrate": "pnpm db:migrate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@nestjs/config": "^4.0.4",
    "@nestjs/mapped-types": "^2.1.1",
    "@prisma/client": "^7.7.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1"
  },
  "devDependencies": {
    "prisma": "^7.7.0"
  }
}

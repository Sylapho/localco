// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "./generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Article {
  id              Int              @id @default(autoincrement())
  nom             String
  category        ArticleCategory  @default(OTHER)
  prixCents       Int
  tvaBps          Int              @default(550)
  stock           Int              @default(0)
  online          Boolean          @default(true)
  emoji           String           @default("🥖")
  imageUrl        String?
  description     String?
  ingredients     String?
  allergenes      String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  nomen           Nomenclature[]
  lignesVente     LigneVente[]
  lignesCmd       LigneCommande[]
  mouvementsStock MouvementStock[]
  stockLots       StockLot[]

  @@index([online])
  @@index([category])
}

enum ArticleCategory {
  JARS
  CUTS
  PREPARATIONS
  SKEWERS
  EGGS
  PACKS
  OTHER
}

model MatierePremiere {
  id                Int              @id @default(autoincrement())
  nom               String
  stock             Float            @default(0)
  unite             String
  coutUnitaireCents Int
  seuil             Float
  conditionnement   String
  nomen             Nomenclature[]
  mouvementsStock   MouvementStock[]
  stockLots         StockLot[]
}

model Nomenclature {
  articleId Int
  mpId      Int
  quantite  Float
  article   Article         @relation(fields: [articleId], references: [id])
  mp        MatierePremiere @relation(fields: [mpId], references: [id])

  @@id([articleId, mpId])
}

model User {
  id        Int      @id @default(autoincrement())
  nom       String
  email     String   @unique
  role      String   @default("vendeur")
  createdAt DateTime @default(now())
  ventes    Vente[]
}

model AuthUser {
  id            String        @id
  name          String
  email         String        @unique
  emailVerified Boolean       @default(false)
  image         String?
  role          String?       @default("vendeur")
  createdAt     DateTime      @default(now()) @db.Timestamp(6)
  updatedAt     DateTime      @default(now()) @db.Timestamp(6)
  sessions      AuthSession[]
  accounts      AuthAccount[]

  @@map("user")
}

model AuthSession {
  id        String   @id
  expiresAt DateTime @db.Timestamp(6)
  token     String   @unique
  createdAt DateTime @default(now()) @db.Timestamp(6)
  updatedAt DateTime @default(now()) @db.Timestamp(6)
  ipAddress String?
  userAgent String?
  userId    String
  user      AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model AuthAccount {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime? @db.Timestamp(6)
  refreshTokenExpiresAt DateTime? @db.Timestamp(6)
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @db.Timestamp(6)
  updatedAt             DateTime  @default(now()) @db.Timestamp(6)
  user                  AuthUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model AuthVerification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @db.Timestamp(6)
  createdAt  DateTime @default(now()) @db.Timestamp(6)
  updatedAt  DateTime @default(now()) @db.Timestamp(6)

  @@map("verification")
}

model Vente {
  id            Int          @id @default(autoincrement())
  date          DateTime     @default(now())
  totalTtcCents Int
  totalHtCents  Int
  tvaCents      Int
  mode          String
  remiseCents   Int          @default(0)
  userId        Int?
  user          User?        @relation(fields: [userId], references: [id])
  lignes        LigneVente[]
}

model LigneVente {
  id            Int     @id @default(autoincrement())
  venteId       Int
  articleId     Int
  quantite      Int
  prixUnitCents Int
  tvaBps        Int
  vente         Vente   @relation(fields: [venteId], references: [id])
  article       Article @relation(fields: [articleId], references: [id])
}

model Commande {
  id            Int                        @id @default(autoincrement())
  trackingToken String                     @unique
  nom           String
  email         String
  tel           String?
  totalTtcCents Int
  lieu          String
  dateRetrait   DateTime?
  statut        String                     @default("nouvelle")
  stripeId      String?
  createdAt     DateTime                   @default(now())
  lignes        LigneCommande[]
  historique    CommandeStatutHistorique[]
  reservationRelease CommandeReservationRelease?
  stockAllocations CommandeStockAllocation[]
  stripeCheckoutReconciliations StripeCheckoutReconciliation[]

  @@index([statut])
  @@index([stripeId])
  @@index([dateRetrait])
}

model PickupPoint {
  id                        Int      @id @default(autoincrement())
  label                     String
  address                   String
  schedule                  String
  allowedWeekdays           Int[]
  alternatingWeekAnchorDate String?
  active                    Boolean  @default(true)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@unique([label, schedule])
  @@index([active])
}

model CommandeReservationRelease {
  id         Int      @id @default(autoincrement())
  commandeId Int      @unique
  commande   Commande @relation(fields: [commandeId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model LigneCommande {
  id                  Int                       @id @default(autoincrement())
  commandeId          Int
  articleId           Int
  quantite            Int
  quantitePrecommande Int                       @default(0)
  prixUnitCents       Int
  commande            Commande                  @relation(fields: [commandeId], references: [id])
  article             Article                   @relation(fields: [articleId], references: [id])
  stockAllocations    CommandeStockAllocation[]

  @@unique([id, commandeId])
  @@index([commandeId])
  @@index([articleId])
}

model CommandeStockAllocation {
  id               Int            @id @default(autoincrement())
  commandeId       Int
  ligneCommandeId  Int
  stockLotId       Int
  quantity         Float
  restoredAt       DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  commande         Commande       @relation(fields: [commandeId], references: [id], onDelete: Cascade)
  ligneCommande    LigneCommande  @relation(fields: [ligneCommandeId, commandeId], references: [id, commandeId], onDelete: Cascade)
  stockLot         StockLot       @relation(fields: [stockLotId], references: [id], onDelete: Restrict)

  @@index([commandeId])
  @@index([ligneCommandeId])
  @@index([stockLotId])
  @@index([commandeId, restoredAt])
  @@unique([ligneCommandeId, stockLotId])
}

model CommandeStatutHistorique {
  id              Int      @id @default(autoincrement())
  commandeId      Int
  ancienStatut    String?
  nouveauStatut   String
  motif           String?
  createdByUserId String?
  createdAt       DateTime @default(now())
  commande        Commande @relation(fields: [commandeId], references: [id], onDelete: Cascade)
}

enum StripeWebhookEventStatus {
  processing
  processed
  failed
}

model StripeWebhookEvent {
  id                  Int                      @id @default(autoincrement())
  eventId             String                   @unique
  type                String
  status              StripeWebhookEventStatus @default(processing)
  attempts            Int                      @default(1)
  lastError           String?
  processingStartedAt DateTime                 @default(now())
  processedAt         DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt

  @@index([status, processingStartedAt])
}

enum StripeCheckoutReconciliationOperation {
  expire_checkout_session
  review_paid_pending_checkout
  review_paid_cancelled_checkout
  review_checkout_payment_mismatch
  review_checkout_attachment_conflict
  review_missing_checkout_session
  review_unmatched_checkout_session
}

enum StripeCheckoutReconciliationStatus {
  pending
  manual_review
  resolved
  failed
}

enum StripeCheckoutReconciliationAttemptOrigin {
  automatic
  manual
}

enum StripeCheckoutReconciliationAttemptResult {
  resolved
  retry_scheduled
  failed
  manual_review
  skipped
}

model StripeCheckoutReconciliation {
  id                     Int                                    @id @default(autoincrement())
  commandeId             Int?
  stripeSessionId        String
  operation              StripeCheckoutReconciliationOperation
  status                 StripeCheckoutReconciliationStatus     @default(pending)
  attempts               Int                                    @default(0)
  lastError              String?
  lastAttemptedAt        DateTime?
  nextAttemptAt          DateTime                               @default(now())
  claimedAt              DateTime?
  claimedBy              String?
  leaseExpiresAt         DateTime?
  failedAt               DateTime?
  resolvedAt             DateTime?
  manualReviewReason     String?
  manualResolution       String?
  manualResolvedByUserId String?
  metadata               Json?
  createdAt              DateTime                               @default(now())
  updatedAt              DateTime                               @updatedAt
  commande               Commande?                              @relation(fields: [commandeId], references: [id], onDelete: SetNull)
  attemptsHistory        StripeCheckoutReconciliationAttempt[]

  @@index([status, operation])
  @@index([status, nextAttemptAt])
  @@index([claimedBy, leaseExpiresAt])
  @@index([commandeId])
  @@index([stripeSessionId])
}

model StripeCheckoutReconciliationAttempt {
  id               Int                                         @id @default(autoincrement())
  reconciliationId Int
  attemptNumber    Int
  origin           StripeCheckoutReconciliationAttemptOrigin
  action           String
  stripeState      String?
  localState       String?
  result           StripeCheckoutReconciliationAttemptResult?
  error            String?
  workerId         String?
  metadata         Json?
  startedAt        DateTime                                    @default(now())
  finishedAt       DateTime?
  reconciliation   StripeCheckoutReconciliation                @relation(fields: [reconciliationId], references: [id], onDelete: Cascade)

  @@index([reconciliationId, startedAt])
  @@index([origin, startedAt])
}

model JourneeCaisse {
  id            Int      @id @default(autoincrement())
  date          DateTime @unique
  totalTtcCents Int
  totalHtCents  Int
  tvaCents      Int
  especesCents  Int
  cbCents       Int
  chequesCents  Int
  margeCents    Int
  nbVentes      Int
  clotureeA     DateTime @default(now())
}

model MouvementStock {
  id              Int      @id @default(autoincrement())
  type            String
  cible           String
  articleId       Int?
  mpId            Int?
  quantite        Float
  stockAvant      Float
  stockApres      Float
  motif           String?
  reference       String?
  createdByUserId String?
  createdAt       DateTime @default(now())

  article Article?         @relation(fields: [articleId], references: [id], onDelete: Cascade)
  mp      MatierePremiere? @relation(fields: [mpId], references: [id], onDelete: Cascade)
}

model StockLot {
  id                Int       @id @default(autoincrement())
  target            String
  articleId         Int?
  mpId              Int?
  initialQuantity   Float
  remainingQuantity Float
  expiresAt         DateTime?
  reference         String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  article Article?         @relation(fields: [articleId], references: [id])
  mp      MatierePremiere? @relation(fields: [mpId], references: [id])
  commandeStockAllocations CommandeStockAllocation[]

  @@index([target, expiresAt])
  @@index([articleId])
  @@index([mpId])
}

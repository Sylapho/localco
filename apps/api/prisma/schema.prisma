// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Article {
  id              Int              @id @default(autoincrement())
  nom             String
  prixCents       Int
  tvaBps          Int              @default(550)
  stock           Int              @default(0)
  online          Boolean          @default(true)
  emoji           String           @default("🥖")
  imageUrl        String?
  description     String?
  ingredients     String?
  allergenes      String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  nomen           Nomenclature[]
  lignesVente     LigneVente[]
  lignesCmd       LigneCommande[]
  mouvementsStock MouvementStock[]
  stockLots       StockLot[]

  @@index([online])
}

model MatierePremiere {
  id              Int              @id @default(autoincrement())
  nom             String
  stock           Float
  unite           String
  coutUnitaireCents Int
  seuil           Float
  conditionnement String
  nomen           Nomenclature[]
  mouvementsStock MouvementStock[]
  stockLots       StockLot[]
}

model Nomenclature {
  articleId Int
  mpId      Int
  quantite  Float
  article   Article         @relation(fields: [articleId], references: [id])
  mp        MatierePremiere @relation(fields: [mpId], references: [id])

  @@id([articleId, mpId])
}

model User {
  id        Int      @id @default(autoincrement())
  nom       String
  email     String   @unique
  role      String   @default("vendeur")
  createdAt DateTime @default(now())
  ventes    Vente[]
}

model Vente {
  id             Int          @id @default(autoincrement())
  date           DateTime     @default(now())
  totalTtcCents  Int
  totalHtCents   Int
  tvaCents       Int
  mode           String
  remiseCents    Int          @default(0)
  userId         Int?
  user           User?        @relation(fields: [userId], references: [id])
  lignes         LigneVente[]
}

model LigneVente {
  id             Int     @id @default(autoincrement())
  venteId        Int
  articleId      Int
  quantite       Int
  prixUnitCents  Int
  tvaBps         Int
  vente          Vente   @relation(fields: [venteId], references: [id])
  article        Article @relation(fields: [articleId], references: [id])
}

model Commande {
  id          Int                       @id @default(autoincrement())
  nom         String
  email       String
  tel         String?
  totalTtcCents Int
  lieu        String
  dateRetrait DateTime?
  statut      String                    @default("nouvelle")
  stripeId    String?
  createdAt   DateTime                  @default(now())
  lignes      LigneCommande[]
  historique  CommandeStatutHistorique[]

  @@index([statut])
  @@index([stripeId])
  @@index([dateRetrait])
}

model LigneCommande {
  id             Int      @id @default(autoincrement())
  commandeId     Int
  articleId      Int
  quantite       Int
  prixUnitCents  Int
  commande       Commande @relation(fields: [commandeId], references: [id])
  article        Article  @relation(fields: [articleId], references: [id])
}

model CommandeStatutHistorique {
  id              Int      @id @default(autoincrement())
  commandeId      Int
  ancienStatut    String?
  nouveauStatut   String
  motif           String?
  createdByUserId String?
  createdAt       DateTime @default(now())
  commande        Commande @relation(fields: [commandeId], references: [id], onDelete: Cascade)
}

model StripeWebhookEvent {
  id          Int      @id @default(autoincrement())
  eventId     String   @unique
  type        String
  processedAt DateTime @default(now())
}

model JourneeCaisse {
  id             Int      @id @default(autoincrement())
  date           DateTime @unique
  totalTtcCents  Int
  totalHtCents   Int
  tvaCents       Int
  especesCents   Int
  cbCents        Int
  chequesCents   Int
  margeCents     Int
  nbVentes       Int
  clotureeA      DateTime @default(now())
}

model MouvementStock {
  id              Int      @id @default(autoincrement())
  type            String
  cible           String
  articleId       Int?
  mpId            Int?
  quantite        Float
  stockAvant      Float
  stockApres      Float
  motif           String?
  reference       String?
  createdByUserId String?
  createdAt       DateTime @default(now())

  article Article?         @relation(fields: [articleId], references: [id], onDelete: Cascade)
  mp      MatierePremiere? @relation(fields: [mpId], references: [id], onDelete: Cascade)
}

model StockLot {
  id                Int      @id @default(autoincrement())
  target            String
  articleId         Int?
  mpId              Int?
  initialQuantity   Float
  remainingQuantity Float
  expiresAt         DateTime?
  reference         String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  article Article?         @relation(fields: [articleId], references: [id])
  mp      MatierePremiere? @relation(fields: [mpId], references: [id])

  @@index([target, expiresAt])
  @@index([articleId])
  @@index([mpId])
}

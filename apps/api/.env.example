NODE_ENV=development
PORT=4000

DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

BETTER_AUTH_SECRET=replace-with-a-long-random-string
BETTER_AUTH_URL=http://localhost:4000

FRONTEND_URL=http://localhost:3000
SHOP_PUBLIC_URL=http://localhost:3001
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
CHECKOUT_RATE_LIMIT_WINDOW_MS=60000
CHECKOUT_RATE_LIMIT_MAX=10
# The checkout rate limit uses process-local memory in development.
# In production with multiple API instances, enforce a shared limit at the
# ingress/API gateway level or replace the store with shared infrastructure.
ABANDONED_ORDER_DELAY_MINUTES=60
# Pending checkout orders older than this delay can be cancelled by the
# abandoned-order cleanup command. Schedule the command independently.

# Required for /api/health/ready to report Stripe as configured.
# Use a real Stripe test secret key, for example sk_test_...
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_WEBHOOK_PROCESSING_TIMEOUT_MS=300000
# If a webhook stays in processing longer than this timeout, a later Stripe
# retry may reclaim it. Keep this above the normal webhook processing duration.
STRIPE_RECONCILIATION_WORKER_ENABLED=false
STRIPE_RECONCILIATION_WORKER_INTERVAL_MS=60000
STRIPE_RECONCILIATION_BATCH_SIZE=10
STRIPE_RECONCILIATION_MAX_ATTEMPTS=5
STRIPE_RECONCILIATION_BACKOFF_BASE_MS=60000
STRIPE_RECONCILIATION_BACKOFF_MAX_MS=3600000
STRIPE_RECONCILIATION_LEASE_MS=300000

# Required for /api/health/ready to report Resend as configured.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
